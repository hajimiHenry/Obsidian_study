settings.outformat=\"png\";
settings.prc = false;
settings.render = 0;
size(900);
import three;
currentprojection = perspective(8,6,4);
draw(O--3.5X, arrow=Arrow3(), black+1.0);
draw(O--3.5Y, arrow=Arrow3(), black+1.0);
draw(O--3.5Z, arrow=Arrow3(), black+1.0);
label(\"$x$\", 3.5X, E, fontsize(14));
label(\"$y$\", 3.5Y, N, fontsize(14));
label(\"$z$\", 3.5Z, N, fontsize(14));
triple A = (3,0,0);
triple B = (0,3,0);
triple C = (0,0,3);
path3 p = A--B--C--cycle;
draw(surface(p), lightgrey+opacity(0.35));
draw(p, black+1.2);
label(\"$\\Pi:\\,x+y+z=3$\", (1.2,2.0,1.0), fontsize(12));
triple M0 = (1,1,1);
triple M = (2,1,0);
triple n = unit((1,1,1));
draw(M0--M, blue+1.5, arrow=Arrow3());
label(\"$\\overrightarrow{M_0M}$\", (M0+M)/2 + 0.25*unit(cross(M-M0,n)), SE, fontsize(11));
triple nTip = M0 + 1.6*n;
draw(M0--nTip, red+1.5, arrow=Arrow3());
label(\"$\\mathbf{n}=(A,B,C)$\", nTip + 0.25*n, N, fontsize(11));
triple u = unit(M - M0);
triple v = unit(n);
real s = 0.14;
triple a1 = M0 + s*u;
triple b1 = M0 + s*v;
triple c1 = M0 + s*u + s*v;
draw(a1--c1--b1, black+2.0);
triple a2 = M0 + 0.7*s*u + 0.08*s*v;
triple b2 = M0 + 0.08*s*u + 0.7*s*v;
triple c2 = M0 + 0.7*s*u + 0.7*s*v;
draw(a2--c2--b2, black+1.0);
triple perpLabel = M0 + 0.60*s*u + 0.60*s*v + 0.10*unit(cross(u,v));
label(\"$90^\\circ$\", perpLabel, fontsize(11));
// no dot, no M0/M labels
